# Kopiér til gateway/.env (som IKKE committes) og udfyld.

# Supabase Edge Functions-basen (projekt-ref rjlxmdfmktucunxehtqz).
FUNCTIONS_BASE=https://rjlxmdfmktucunxehtqz.supabase.co/functions/v1

# Delt token der beskytter sftp-auth/sftp-uploaded. SKAL matche edge-secret'en
# SFTP_HOOK_SECRET (supabase secrets set SFTP_HOOK_SECRET=...). Vælg en lang,
# tilfældig streng.
SFTP_HOOK_SECRET=CHANGE_ME_long_random_string

# SFTPGo admin-UI (kun tilgængeligt på 127.0.0.1:8080).
SFTPGO_ADMIN_USER=admin
SFTPGO_ADMIN_PASSWORD=CHANGE_ME_admin_password
